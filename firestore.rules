rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /userData/{userId}/entries/{entryId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /userData/{userId}/payments/{paymentId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /userData/{userId}/expenses/{expenseId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}